generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 String             @id @default(cuid())
  username           String             @unique
  password           String
  passcode           String?
  name               String?
  streakLabel        String             @default("Streaks")
  createdAt          DateTime           @default(now())
  categories         Category[]
  streaks            Streak[]
  syllabi            Syllabus[]
  timeTrackers       TimeTracker[]
}

model Streak {
  id        String      @id @default(cuid())
  name      String
  order     Int         @default(0)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  logs      StreakLog[]
}

model StreakLog {
  id        String   @id @default(cuid())
  date      String
  streakId  String
  streak    Streak   @relation(fields: [streakId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([streakId, date])
}

model Category {
  id        String    @id @default(cuid())
  name      String
  icon      String?
  order     Int       @default(0)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  subjects  Subject[]
}

model Subject {
  id         String   @id @default(cuid())
  name       String
  order      Int      @default(0)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  rooms      Room[]
}

model Room {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  notes     Note[]
  links     Link[]
  files     File[]
}

model Note {
  id        String   @id @default(cuid())
  title     String?
  content   String
  order     Int      @default(0)
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Link {
  id        String   @id @default(cuid())
  title     String?
  url       String
  order     Int      @default(0)
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model File {
  id        String   @id @default(cuid())
  name      String
  path      String
  size      Int
  mimeType  String
  type      String
  order     Int      @default(0)
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Syllabus {
  id        String          @id @default(cuid())
  name      String
  order     Int             @default(0)
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  members   TrackerMember[]
  topics    TrackerTopic[]
}

model TrackerMember {
  id         String            @id @default(cuid())
  name       String
  syllabusId String
  syllabus   Syllabus          @relation(fields: [syllabusId], references: [id], onDelete: Cascade)
  createdAt  DateTime          @default(now())
  progress   TrackerProgress[]
}

model TrackerTopic {
  id         String        @id @default(cuid())
  name       String
  order      Int           @default(0)
  syllabusId String
  syllabus   Syllabus      @relation(fields: [syllabusId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())
  items      TrackerItem[]
}

model TrackerItem {
  id        String            @id @default(cuid())
  name      String
  order     Int               @default(0)
  topicId   String
  topic     TrackerTopic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())
  progress  TrackerProgress[]
}

model TrackerProgress {
  id        String        @id @default(cuid())
  memberId  String
  member    TrackerMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  itemId    String
  item      TrackerItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([memberId, itemId])
}

model TimeTracker {
  id        String              @id @default(cuid())
  name      String
  order     Int                 @default(0)
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  members   TimeTrackerMember[]
}

model TimeTrackerMember {
  id        String      @id @default(cuid())
  name      String
  trackerId String
  tracker   TimeTracker @relation(fields: [trackerId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  entries   TimeEntry[]
}

model TimeEntry {
  id        String            @id @default(cuid())
  date      String
  startTime String?
  endTime   String?
  minutes   Int
  note      String?
  memberId  String
  member    TimeTrackerMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())
}

